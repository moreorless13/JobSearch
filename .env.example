OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REDIS_URL=redis://localhost:6379/0
JOB_TRACKER_SHEET_URL=
GMAIL_SEARCH_MAX_RESULTS=25
# Optional credential override. Leave these unset when using ambient ADC.
# File-based credentials may be either a service-account key JSON or an ADC JSON file.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Optional for keyless delegated auth if ADC cannot infer the runtime service account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DELEGATED_USER=
GMAIL_DELEGATED_USER=
JOB_AGENT_QA_LLM_JUDGE_ENABLED=
