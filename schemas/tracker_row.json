    "company": { "type": ["string", "null"] },
    "role_title": { "type": ["string", "null"] },
    "location": { "type": ["string", "null"] },
    "source": { "type": ["string", "null"] },
    "posting_url": { "type": ["string", "null"], "format": "uri" },
    "careers_url": { "type": ["string", "null"], "format": "uri" },
    "recruiter_name": { "type": ["string", "null"] },
    "contact_email": { "type": ["string", "null"], "format": "email" },
    "status": { "type": ["string", "null"] },
    "applied_date": { "type": ["string", "null"], "format": "date" },
    "follow_up_date": { "type": ["string", "null"], "format": "date" },
    "interview_date": { "type": ["string", "null"], "format": "date" },
    "offer_date": { "type": ["string", "null"], "format": "date" },
