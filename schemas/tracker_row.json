    "salary": { "type": ["string", "null"] },
    "remote_or_local": { "type": ["string", "null"] },
    "email_update_type": { "type": ["string", "null"] },
    "last_email_update": { "type": ["string", "null"] },
    "next_steps": { "type": ["string", "null"] },
